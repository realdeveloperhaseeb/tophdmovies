# ─── MySQL (Hostinger Business plan) ───────────────────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_PORT=3306

# ─── Admin login (no public registration) ──────────────────────────
ADMIN_USERNAME=tophdmoviesadmin
ADMIN_PASSWORD=tophdmoviespassword
# Used to sign the session cookie. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret

# ─── Public site config ────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=TopHDMovies
NEXT_PUBLIC_SITE_URL=https://tophdmovies.com
